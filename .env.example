# Telegram
TG_BOT_TOKEN=YOUR_BOT_TOKEN_FROM_BOTFATHER
TG_CHANNEL_ID=@kydaidy
TG_ADMIN_ID=YOUR_TELEGRAM_USER_ID

# Tribute (получишь в личном кабинете Tribute)
TRIBUTE_API_KEY=YOUR_TRIBUTE_API_KEY
TRIBUTE_WEBHOOK_SECRET=YOUR_TRIBUTE_WEBHOOK_SECRET

# Tally (опционально, для webhook верификации)
TALLY_WEBHOOK_SECRET=YOUR_TALLY_WEBHOOK_SECRET

# Hosting (для webhook URL)
WEBHOOK_BASE_URL=https://your-app.onrender.com
WEBHOOK_PATH=/tg-webhook
PORT=8080

# DB (SQLite на старте, потом PostgreSQL)
DATABASE_URL=sqlite+aiosqlite:///./kydaidy.db

# Бизнес-логика
MANIFEST_7_PRICE=1990
MANIFEST_CLUB_PRICE=990
MANIFEST_PLUS_PRICE=4990
ONE_ON_ONE_PRICE=7000
